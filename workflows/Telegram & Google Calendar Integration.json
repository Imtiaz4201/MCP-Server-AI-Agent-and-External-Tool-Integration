{
  "name": "Telegram & Google Calendar Integration",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.2,
      "position": [-256, -32],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Telegram Trigger",
      "webhookId": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an AI assistant designed to manage calendar events for the user.\n\nYour capabilities include:\n- Creating events\n- Retrieving events\n- Updating events\n- Deleting events\n\nTime & Timezone Rules:\n1. Current time reference: {{$now}}\n2. User's Local Timezone: Asia/Bangkok\n3. When creating an event, if no end time is specified, always set it for 1 hour after the start time.\n4. Ensure all timestamps sent to tools use the ISO 8601 format with the +07:00 offset.\n\nImportant guidelines:\n1. Always provide a name for the event. If the user doesn't provide one, name it \"New Event.\"\n2. To update or delete an event, you must first retrieve the event ID using the "get event" tool.\n   - Without the ID, you cannot successfully edit or delete the event.\n\nUser input:\n{{$json.message.text}}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [-32, -32],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": "qwen/qwen3-32b",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [-128, 192],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "YOUR_TELEGRAM_CHAT_ID",
        "contextWindowLength": 10
      },
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.3,
      "position": [32, 192],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Simple Memory"
    },
    {
      "parameters": {
        "calendar": {
          "__rl": true,
          "value": "YOUR_GOOGLE_ACCOUNT_EMAIL",
          "mode": "list",
          "cachedResultName": "YOUR_GOOGLE_ACCOUNT_EMAIL"
        },
        "start": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Start', ``, 'string') }}",
        "end": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('End', ``, 'string') }}",
        "useDefaultReminders": false,
        "additionalFields": {
          "summary": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Summary', ``, 'string') }}"
        }
      },
      "type": "n8n-nodes-base.googleCalendarTool",
      "typeVersion": 1.3,
      "position": [208, 192],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Create an event in Google Calendar",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "YOUR_GOOGLE_CALENDAR_CREDENTIAL_ID",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "operation": "getAll",
        "calendar": {
          "__rl": true,
          "value": "YOUR_GOOGLE_ACCOUNT_EMAIL",
          "mode": "list",
          "cachedResultName": "YOUR_GOOGLE_ACCOUNT_EMAIL"
        },
        "limit": 10,
        "timeMin": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('After', ``, 'string') }}",
        "timeMax": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Before', ``, 'string') }}",
        "options": {
          "fields": ""
        }
      },
      "type": "n8n-nodes-base.googleCalendarTool",
      "typeVersion": 1.3,
      "position": [368, 192],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Get many events in Google Calendar",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "YOUR_GOOGLE_CALENDAR_CREDENTIAL_ID",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "operation": "delete",
        "calendar": {
          "__rl": true,
          "value": "YOUR_GOOGLE_ACCOUNT_EMAIL",
          "mode": "list",
          "cachedResultName": "YOUR_GOOGLE_ACCOUNT_EMAIL"
        },
        "eventId": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Event_ID', ``, 'string') }}",
        "options": {}
      },
      "type": "n8n-nodes-base.googleCalendarTool",
      "typeVersion": 1.3,
      "position": [528, 192],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Delete an event in Google Calendar",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "YOUR_GOOGLE_CALENDAR_CREDENTIAL_ID",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "operation": "update",
        "calendar": {
          "__rl": true,
          "value": "YOUR_GOOGLE_ACCOUNT_EMAIL",
          "mode": "list",
          "cachedResultName": "YOUR_GOOGLE_ACCOUNT_EMAIL"
        },
        "eventId": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Event_ID', ``, 'string') }}",
        "useDefaultReminders": false,
        "updateFields": {
          "end": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('End', ``, 'string') }}",
          "start": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Start', ``, 'string') }}",
          "summary": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Summary', ``, 'string') }}"
        }
      },
      "type": "n8n-nodes-base.googleCalendarTool",
      "typeVersion": 1.3,
      "position": [672, 192],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Update an event in Google Calendar",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "YOUR_GOOGLE_CALENDAR_CREDENTIAL_ID",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "={{ $json.output }}",
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [368, -32],
      "id": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "name": "Send a text message",
      "webhookId": "xxxx-xxxx-xxxx-xxxx-xxxx",
      "credentials": {
        "telegramApi": {
          "id": "YOUR_TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram account"
        }
      }
    }
  ],
  "pinData": {},
  "connections": {
    "Telegram Trigger": {
      "main": [[{"node": "AI Agent", "type": "main", "index": 0}]]
    },
    "Groq Chat Model": {
      "ai_languageModel": [[{"node": "AI Agent", "type": "ai_languageModel", "index": 0}]]
    },
    "Simple Memory": {
      "ai_memory": [[{"node": "AI Agent", "type": "ai_memory", "index": 0}]]
    },
    "Create an event in Google Calendar": {
      "ai_tool": [[{"node": "AI Agent", "type": "ai_tool", "index": 0}]]
    },
    "Get many events in Google Calendar": {
      "ai_tool": [[{"node": "AI Agent", "type": "ai_tool", "index": 0}]]
    },
    "Delete an event in Google Calendar": {
      "ai_tool": [[{"node": "AI Agent", "type": "ai_tool", "index": 0}]]
    },
    "Update an event in Google Calendar": {
      "ai_tool": [[{"node": "AI Agent", "type": "ai_tool", "index": 0}]]
    },
    "AI Agent": {
      "main": [[{"node": "Send a text message", "type": "main", "index": 0}]]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "xxxx-xxxx-xxxx-xxxx-xxxx",
  "meta": {
    "templateCredsSetupCompleted": true,
    "instanceId": "xxxx-instance-id-removed-xxxx"
  },
  "id": "xxxx-workflow-id-xxxx",
  "tags": []
